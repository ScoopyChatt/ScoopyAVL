# Express API port
PORT=3001

# CORS — set to your frontend domain in production
CORS_ORIGIN=https://scoopychatt.com

# PocketBase service URL (set to your Railway PocketBase service URL)
POCKETBASE_URL=http://localhost:8090

# PocketBase superuser credentials
PB_SUPERUSER_EMAIL=your-admin@email.com
PB_SUPERUSER_PASSWORD=your-strong-password

# Google APIs
GOOGLE_PLACES_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
